{
  "name": "ladder",
  "version": "0.1.0",
  "description": "CLI RSS reader — fastladder のオマージュ",
  "type": "module",
  "bin": {
    "ladder": "./bin/ladder.cjs"
  },
  "scripts": {
    "dev": "tsx bin/ladder.ts",
    "build": "esbuild bin/ladder.ts --bundle --platform=node --format=cjs --outfile=bin/ladder.cjs --external:better-sqlite3 --external:neo-blessed",
    "start": "node bin/ladder.cjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^9.0.0",
    "commander": "^12.0.0",
    "fast-xml-parser": "^4.0.0",
    "html-to-text": "^9.0.0",
    "neo-blessed": "^0.2.0",
    "node-fetch": "^3.3.0",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.0.0",
    "@types/html-to-text": "^9.0.0",
    "@types/node": "^20.0.0",
    "esbuild": "^0.27.4",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
